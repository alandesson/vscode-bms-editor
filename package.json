{
  "name": "bms-renderer",
  "displayName": "bms-renderer",
  "description": "BMS renderer and language support ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "menus": {
      "editor/title": [
        {
          "command": "bms-renderer.render",
          "when": "resourceLangId == bms",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "bms-renderer.render",
        "title": "Render BMS"
      }
    ],
    "languages": [
      {
        "id": "bms",
        "aliases": ["BMS", "bms"],
        "extensions": [".bms"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bms",
        "scopeName": "source.bms",
        "path": "./syntaxes/bms.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "bms",
        "scopes": {
          "label.italic": ["support.function.label.bms"],
          "continuation": ["markup.bold.bms"]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
